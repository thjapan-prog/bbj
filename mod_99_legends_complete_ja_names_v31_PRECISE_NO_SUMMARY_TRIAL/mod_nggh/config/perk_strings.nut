//-------------
// description
// hexe charm specialized
::Const.Strings.PerkDescription.NggHCharmEnemySpider <- "\'The creepy crawlies in the depth of the forest, they would be suited to be your servants and soldiers.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Webknechtを永続的に魅了できるようになる。"
		+ "\n• Redback Spiderを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• net、web、grasping vinesによる拘束に対する[color=" + ::Const.UI.Color.PositiveValue + "]免疫[/color]を得る。";

::Const.Strings.PerkDescription.NggHCharmEnemyDirewolf <- "\'Who wouldn\'t want to own a 5 feet tall pet dog. Nothing could be better than seeing them mauling fools who dare to make an enemy of you.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]\n• Direwolf、Hyena、Bearを永続的に魅了できるようになる。"
		+ "\n• White Direwolfを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]8%[/color]増加し、移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]2[/color]減少する。";

::Const.Strings.PerkDescription.NggHCharmEnemyAlp <- "\'Dream eater or nightmare caller, such creatures should be servants for a beauty likes you.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Alpを永続的に魅了できるようになる。"
		+ "\n• Demon Alpを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 恐怖、パニック、精神支配効果に対する士気判定で意思が[color=" + ::Const.UI.Color.PositiveValue + "]+15[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Sleep[/color]スキルの対象を眠らせる確率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemyGhoul <- "\'Hungry monkeys or big fricking starving gorillas are probably nice exotic pets.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Nachzehrerを永続的に魅了できるようになる。"
		+ "\n• Skin Ghoulを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemyUnhold <- "\'Giants that can even dwarf the tallest orc. You would want mighty creatures as them to be your bodyguards.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Unhold、Frost Unhold、Swamp Unhold、Armored Unholdを永続的に魅了できるようになる。"
		+ "\n• Rock Unholdを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemySchrat <- "\'Sentient ancient trees that are seen as guardian of the forest. Having them as your guardians should be more appropriate!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Schratを永続的に魅了できるようになる。"
		+ "\n• Heartwood Schratを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 近接防御と遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• 受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]減少する。精神攻撃や状態異常によるダメージには影響しない。";

::Const.Strings.PerkDescription.NggHCharmEnemyLindwurm <- "\'Some say they are giant serpents, some call them as dragons. All to describe certain fearsome beasts that have acidic blood and a towering body. Imagine of having one under your command.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Lindwurmを永続的に魅了できるようになる。"
		+ "\n• Stollwurmを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 近接戦闘中のあらゆる敵の意思を、自身の現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]に等しい値だけ減少させる。";

::Const.Strings.PerkDescription.NggHCharmEnemyOrk <- "\'Warriors with physical strength that no human can match. Such brute strength should be used to fight for your causes.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Orc Berserker、Orc Warrior、Orc Eliteを永続的に魅了できるようになる。"
		+ "\n• Orc WarlordとOrc Behemothを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• イニシアチブは蓄積した疲労の全量ではなく、その[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]分だけ減少する。";

::Const.Strings.PerkDescription.NggHCharmEnemyGoblin <- "\'Goblins might be small and weak but they have tons of trick up their sleeves. Such cunning creatures are good for certain jobs.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Goblin OverseerとGoblin Shamanを永続的に魅了できるようになる。"
		+ "\n• overwhelmed状態に対する[color=" + ::Const.UI.Color.PositiveValue + "]免疫[/color]を得る。"
		+ "\n• 遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]ポイント増加する。";
// hexe charm base
::Const.Strings.PerkDescription.NggHCharmBasic <- "\'Learn the basic of how to steal other\'s heart. First lesson, with a good pair of ripe and juicy pears, men will fall for your charm.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]の取引能力を得て、売却価格が上がり、購入価格が下がり、配送契約の報酬が増加する。";

::Const.Strings.PerkDescription.NggHCharmWords <- "\'Enchanted words that can wake up any sleeping snake down below.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• より強力な人間、たとえばKnight、Sergent、Officer、Nomad Leader、Bandit Leader、Barbarian Chosenなどにも魅了を行えるようになる。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmAppearance <- "\'A gorgeous appearance that no men can resist. How can such beauty exist?\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Swordmaster、Blade Dancer、Master Archer、Desert Stalker、Hedge Knight、Nomad Executioner、Barbarian King、Bandit Warlordを魅了できるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charmed[/color]効果の持続時間が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] turns増加する。この追加持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]Resilient[/color]パークでは減少しない。";

::Const.Strings.PerkDescription.NggHCharmSpec <- "\'Master the art of capturing other\'s heart. Don\'t you want a dommy mommy? C\'mere! Let mommy comfort you!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• Championの敵を永続的に魅了できるようになる。\n• Orc Warlord、Orc Behemoth、Legendary beastsを永続的に魅了するための最後の条件を満たす。";

::Const.Strings.PerkDescription.NggHCharmNudist <- "\'Real slut doesn\'t need cloth.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n防具と兜の両方を装備していない間、以下の効果を得る：\n"
		+ "\n• nimbleのスタックをさらに1つ得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";
// hexe hex
::Const.Strings.PerkDescription.NggHHexHexer <- "\'You have no idea how much power a hexer has over their curses.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果を受けている対象を攻撃する際、以下の効果を適用する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]増加する。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHHexMastery <- "\'Master the art of hexing, your ability to curse someone has never been this good before.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Protected by a Hex[/color]効果がある場合、APコストを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]だけ減少させる。"
		+ "\n• 経験値獲得量が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHHexSharePain <- "\'No one should be in pain alone!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 視界内の別のランダムな敵1体にも追加で[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果を付与する。"
		+ "\n• 各ラウンドに1回、[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果以外のあらゆるダメージ源によって自身のhex対象1体が受けたダメージは、他のhex対象にも与えられる。自身は対象外。";

::Const.Strings.PerkDescription.NggHHexSuffering <- "\'A curse that brings a greater suffer! Let them take on your burden.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]Hex of Suffering[/color]に強化される。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]18%[/color]増加する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Hex of Sufferingの効果：[/u][/color]"
		+ "\n• 特定の種類の負の状態異常（[color=" + ::Const.UI.Color.NegativeValue + "]Bleeding[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Poisoned[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Dazed[/color]など）をhex対象へ移し替える"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexWeakening <- "\'A curse that can cause one to be weak and old.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]Hex of Weakening[/color]に強化される。"
		+ "\n• 1ターンごとの疲労回復量が[color=" + ::Const.UI.Color.PositiveValue + "]14%[/color]増加する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Hex of Weakeningの効果：[/u][/color]"
		+ "\n• 攻撃ダメージ[color=" + ::Const.UI.Color.NegativeValue + "]-40%[/color]"
		+ "\n• 最大疲労[color=" + ::Const.UI.Color.NegativeValue + "]-33%[/color]"
		+ "\n• 1ターンごとの疲労回復量[color=" + ::Const.UI.Color.NegativeValue + "]-5[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexVulnerability <- "\'A curse that causes new wounds to become more severe than usual.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]Hex of Vulnerability[/color]に強化される。"
		+ "\n• ヒットポイントへの被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント減少する。"
		+ "\n• 防具への被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15[/color]ポイント減少する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Hex of Vulnerabilityの効果：[/u][/color]"
		+ "\n• 受けるダメージ[color=" + ::Const.UI.Color.NegativeValue + "]+15%[/color]"
		+ "\n• イニシアチブ[color=" + ::Const.UI.Color.NegativeValue + "]-25%[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexMisfortune <- "\'A curse that brings bad luck.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]Hex of Misfortune[/color]に強化される。"
		+ "\n• あらゆる攻撃者に対して命中させるために2回の攻撃判定成功を要求する確率を[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]得る。"
		+ "\n• あらゆる負の士気判定が自身に影響するために2回の判定成功を要求する確率を[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]得る。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Hex of Misfortuneの効果：[/u][/color]"
		+ "\n• 合計命中率[color=" + ::Const.UI.Color.NegativeValue + "]-12%[/color]"
		+ "\n• 合計回避率[color=" + ::Const.UI.Color.NegativeValue + "]-10%[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";
// hexe bdsm
::Const.Strings.PerkDescription.NggH_BDSM_WhipLash <- "\'It\'s so fast, you can hear the cracking sound from a far. How can anyone dodge this?\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n鞭を装備している間、以下の効果を得る：\n"
		+ "\n• 現在のイニシアチブの[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]に等しい近接攻撃スキルを得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]アクティブスキルは、自身と対象の間の1マスごとに攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]、防具貫通が[color=" + ::Const.UI.Color.PositiveValue + "]+6%[/color]増加する。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipMastery <- "\'Master whips to hit where it hurts the most.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• このパークは[color=" + ::Const.UI.Color.NegativeValue + "]Cleaver Mastery[/color]としても扱われる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、対象の[color=" + ::Const.UI.Color.NegativeValue + "]Bleeding[/color]効果1スタックごとに攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。"
		+ "\n• 鞭武器スキルのAPコストが[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]減少する。";

::Const.Strings.PerkDescription.NggH_BDSM_MaskOn <- "\'Dear! Is it kinky to put on a mask?\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n視界に少なくとも[color=" + ::Const.UI.Color.NegativeValue + "]-1[/color]の補正を与える頭装備を着けている間、以下の効果を得る：\n"
		+ "\n• 習得済みのこのパークグループのパーク1つごとに意思が[color=" + ::Const.UI.Color.PositiveValue + "]+3%[/color]増加する（このパークを含む）。"
		+ "\n• 鞭武器スキルの疲労コストを、習得済みのこのパークグループのパーク数だけ減少させる（このパークを含む）。";

::Const.Strings.PerkDescription.NggH_BDSM_Bondage <- "\'Trust me, dear! We\'ll have a fun time.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\nnet、vines、webに捕らわれている敵を有効なスキルで対象にしたとき、以下の効果を適用する：\n"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が[color=" + ::Const.UI.Color.PositiveValue + "]+7%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]、防具貫通が[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Disarm[/color]アクティブスキルの命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+12%[/color]増加する。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipPunish <- "\'Do as mommy said or you will be whipped.\'"
	+"\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• 鞭を装備している間、[color=" + ::Const.UI.Color.NegativeValue + "]Crack the Whip[/color]アクティブスキルを得る。"
		+ "\n• AP4および疲労15を消費する。\n• 射程は[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]マス。"
		+ "\n• 対象に防具を無視する[color=" + ::Const.UI.Color.DamageValue + "]2[/color] - [color=" + ::Const.UI.Color.DamageValue + "]5[/color]ダメージを与える。"
		+ "\n• 対象のsimpに[color=" + ::Const.UI.Color.NegativeValue + "]Whipped[/color]状態を付与し、多くの能力値を2ラウンドの間上昇させる。"
		+ "\n• 対象のsimpの士気が\'Steady\'未満なら\'Steady\'に戻す。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipLove <- "\'It\'s not abuse if they love it.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color] "
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルが命中するたび、その対象に\"whipped\"カウンターを付与する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルは、その対象の\"whipped\"カウンター1つごとに魅了確率が[color=" + ::Const.UI.Color.PositiveValue + "]+4%[/color]増加する[b](max: 20%)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]12%[/color]に等しい追加攻撃ダメージを得る[b](max: 30)[/b]。";

::Const.Strings.PerkDescription.NggH_BDSM_DommyMommy <- "\'Have I told you to stop? Don\'t stop till i say so. Now clean my feet properly with your mouth.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color] "
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Fearsome[/color]パークを無償で得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Crack the Whip[/color]スキルは自身の士気も上昇させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Crack A Whip[/color]スキルによる[color=" + ::Const.UI.Color.NegativeValue + "]Whipped[/color]効果のボーナスが[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]ポイント増加する。";
// luft
::Const.Strings.PerkDescription.NggHLuftPattingSpec <- "\'Master the art of petting head. No head can be left without being petted.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Petting[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Petting[/color]スキルのダメージが[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Petting[/color]スキルは[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]の確率で対象をdistract状態にする。";

::Const.Strings.PerkDescription.NggHLuftUnholyFruits <- "\'Luft has learnt how to use his two unholy fruits for certain purposes.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]の取引能力を得て、売却価格が上がり、購入価格が下がり、配送契約の報酬が増加する。";

::Const.Strings.PerkDescription.NggHLuftInnocentLook <- "\'Using his innocent and smol nacho appearance to make more humans think he\'s cute so he can pet them when they have lower their guard.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n•より強力な人間、たとえばKnight、Sergent、Officer、Nomad Leader、Bandit Leader、Barbarian Chosenなどにも魅了を行えるようになる。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHLuftGhoulBeauty <- "\'A Charming ghoulish body that can make any perverted human falls in love with Luft. They like me! They love me! They let me pet them!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Swordmaster、Blade Dancer、Master Archer、Desert Stalker、Hedge Knight、Nomad Executioner、Barbarian King、Bandit Warlordを魅了できるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charmed[/color]効果の持続時間が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] turns増加する。この追加持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]Resilient[/color]パークでは減少しない。";
// egg
::Const.Strings.PerkDescription.NggHEggBreedingMachine <- "\'Master what you are good at. Producing eggs, not to eat thou!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hatch Egg[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Hatch All Eggs[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 各ターン開始時、[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]の確率で無料の卵を1つ得る。";

::Const.Strings.PerkDescription.NggHEggInherit <- "\'Like father like son.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 孵化したspiderlingはあなたのパークの大半を引き継ぐ。";

::Const.Strings.PerkDescription.NggHEggNaturalSelection <- "\'Let nature do their work.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 後から孵化したspiderlingほど基礎能力値が高くなる。";

::Const.Strings.PerkDescription.NggHEggAttachSpider <- "\'It is sad when you do not have legs. Wishing for a pairs of leg would be asking too much. Well!!! At least you can ask your spider friends for a ride.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• SpiderやWardog、Warhound、Wolfなど特定の生物に騎乗できるようになる。";
// spider
::Const.Strings.PerkDescription.NggH_Spider_Bite <- "\'Strong spider bite that is capable of puncturing the toughest and sturdiest armor.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Webknecht Bite[/color] and [color=" + ::Const.UI.Color.NegativeValue + "]Redback Webknecht Bite[/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]1[/color]-[color=" + ::Const.UI.Color.DamageValue + "]5[/color]増加する。"
		+ "\n• 防具を無視するダメージ割合が追加で[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]の確率で完全に防具を無視する刺突攻撃になる。";

::Const.Strings.PerkDescription.NggH_Spider_Venom <- "\'An even more deadly venom, your poor victim would surely die faster.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 咬みつきで付与する[color=" + ::Const.UI.Color.NegativeValue + "]Poisoned[/color]効果の持続時間が1 turns延長される。"
		+ "\n• 咬みつきで付与する[color=" + ::Const.UI.Color.NegativeValue + "]Redback Poisoned[/color]効果の1ターンごとの継続ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]増加する[b](min: 1)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Poisoned[/color]および[color=" + ::Const.UI.Color.NegativeValue + "]Redback Poisoned[/color]効果は、1スタックごとに対象の疲労消費を[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Webknecht Bite[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Redback Webknecht Bite[/color]スキルの攻撃ダメージは、対象にある[color=" + ::Const.UI.Color.NegativeValue + "]Poisoned[/color]および[color=" + ::Const.UI.Color.NegativeValue + "]Redback Poisoned[/color]効果1スタックごとに[color=" + ::Const.UI.Color.PositiveValue + "]2%[/color]増加する。"
		+ "\n• アンデッドに対してはダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"; //, but if they are trapped in net, vines or web then the bonus is increased to [color=" + ::Const.UI.Color.PositiveValue + "]25%[/color] instead.";

::Const.Strings.PerkDescription.NggH_Spider_Web <- "\'Master the ability to weave and create web so you can make the strongest web with little effort.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Weave Web[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 蓄積疲労が少ないほど、敵はあなたのwebから抜け出しにくくなる。"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• クールダウンを[color=" + ::Const.UI.Color.NegativeValue + "]1[/color] turnに減少させる。";

::Const.Strings.PerkDescription.NggH_Spider_ToughCarapace <- "\'Better than any plate armor.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 防具が受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]減少する。"
		+ "\n• 防具を無視するダメージを[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]減少させる";
// serpent
::Const.Strings.PerkDescription.NggHSerpentBite <- "\'Lightning-fast attack that can deliver more powerful bite.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• APコストは[color=" + ::Const.UI.Color.PositiveValue + "]4[/color]のみ。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]8[/color]-[color=" + ::Const.UI.Color.DamageValue + "]15[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]増加する。";

::Const.Strings.PerkDescription.NggHSerpentDrag <- "\'With strong muscles, any prey can easily be disable in this unbreakable constriction.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 最大射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]マス増加する。"
		+ "\n• さらに最大で[color=" + ::Const.UI.Color.DamageValue + "]15[/color]の防具貫通ダメージも与える。";

::Const.Strings.PerkDescription.NggHSerpentVenom <- "\'Evolve to gain a venom gland to poison your prey. Deadly but doesn\'t persist long.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 1ターンごとに追加で[color=" + ::Const.UI.Color.DamageValue + "]20[/color]の毒ダメージを与える。"
		+ "\n• このパークで付与される[color=" + ::Const.UI.Color.NegativeValue + "]Poisoned[/color]効果は1 turnsのみ持続する。";

::Const.Strings.PerkDescription.NggHSerpentGiant <- "\'What could be more terrifying than a big snake? A gigantic snake!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]スキルは、現在の近接攻撃スキルに応じた確率で引き寄せた対象を[color=" + ::Const.UI.Color.PositiveValue + "]Disarm[/color]する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]スキルで、Knock backおよびGrabに免疫を持つ味方も引き寄せられるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]スキルの攻撃射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]増加する。";
// hyena
::Const.Strings.PerkDescription.NggHHyenaBite <- "\'Razor sharp fangs that are capable of creating gruesome bleeding wounds.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hyena Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]30[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• 咬みつきで与える出血ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。";
// wolf
::Const.Strings.PerkDescription.NggHWolfBite <- "\'Powerful jaw muscles and tough fangs to crush armor and tear flesh apart.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Direwolf Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]10[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]35%[/color]増加する。";

::Const.Strings.PerkDescription.NggHWolfThickHide <- "\'Thick and tough fur that can stop attacks from causing severe injury.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 防具が受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]減少する。"
		+ "\n• 頭部と胴体の防具値に自然防具[color=" + ::Const.UI.Color.PositiveValue + "]75[/color]を得る。";

::Const.Strings.PerkDescription.NggHWolfEnrage <- "\'Fast and furious attacks that leave your overwhelmed victim no way to escape or fight back.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n対象にある[color=" + ::Const.UI.Color.NegativeValue + "]Overwhelmed[/color]効果1スタックごとに、以下の効果を得る：\n"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 防具を無視するダメージ割合が追加で[color=" + ::Const.UI.Color.PositiveValue + "]+2%[/color]増加する。";

::Const.Strings.PerkDescription.NggHWolfRabies <- "\'Your puppy has rabies. That is not good, right? Do not pet it!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]20[/color]ポイント増加する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]20[/color]ポイント増加する。";
// alp
::Const.Strings.PerkDescription.NggHAlpNightmareSpec <- "\'Feed on the nightmare and terror of your victim to restore your own vitality.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]に等しい追加ダメージを得る。"
		+ "\n• 与えたダメージの最大[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]分のヒットポイントを回復する。";

::Const.Strings.PerkDescription.NggHAlpSleepSpec <- "\'Master your ability to put your prey in to sleep easier.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Sleep[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 対象を眠らせる確率が現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]だけ増加する。"
		+ "\n• APコストを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]だけ減少させる。";

::Const.Strings.PerkDescription.NggHAlpAfterWake <- "\'Preys waken up by nightmare are easy to break.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 対象の意思を最大で[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]無視する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]の確率で対象を目覚めさせない。"
		+ "\n• あなたの攻撃で[color=" + ::Const.UI.Color.NegativeValue + "]Sleeping[/color]効果が解除されたとき、その睡眠中の対象に負の士気判定を行う。";

::Const.Strings.PerkDescription.NggHAlpAfterimage <- "\'Become more annoying than ever.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n何らかの方法でテレポートした後、以下の効果を適用する：\n"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Afterimage[/color]効果を得て、近接防御と遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]+15[/color]増加し、次の自分のターン開始時まで持続する。"
		+ "\n• 追加の[color=" + ::Const.UI.Color.NegativeValue + "]Afterimage[/color]スタックは、それぞれ近接防御と遠隔防御を[color=" + ::Const.UI.Color.PositiveValue + "]+5[/color]だけ増加させる。";

::Const.Strings.PerkDescription.NggHAlpLivingNightmare <- "\'What would be more terrifying than a nightmare? A nightmare outside of a dream.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 敵に止めを刺したとき、生けるNightmareを召喚する確率がある。"
		+ "\n• この確率は、その同じ対象に[color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]スキルを使った回数に応じて決まる。";

::Const.Strings.PerkDescription.NggHAlpMindBreak <- "\'Definitely not some dirty shit from hentai.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP4および疲労8を消費する。"
		+ "\n• 防具を無視する[color=" + ::Const.UI.Color.DamageValue + "]5[/color] - [color=" + ::Const.UI.Color.DamageValue + "]10[/color]ダメージを与える。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mind Broken[/color]効果を付与し、対象の意思を[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント低下させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mind Broken[/color]効果は最大3 turns持続し、重ね掛けもできる。";
// demon alp
::Const.Strings.PerkDescription.NggHAlpControlFlame <- "\'Better control over your fire, better safety for you. Be careful when having more than 2 demon alps, their fire can override each other.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Realm of Burning Nightmares[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 炎は術者を傷つけない。";

::Const.Strings.PerkDescription.NggHAlpFieceFlame <- "\'Raging flames that can burn down anything. Hell is here!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Realm of Burning Nightmares[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 火炎ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]20[/color]ポイント増加する。"
		+ "\n• 火炎ダメージは重度の火傷を引き起こすことがある。"
		+ "\n• 炎の持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]半分[/color]になる。";

::Const.Strings.PerkDescription.NggHAlpHellishFlame <- "\'You might like Hell\'s Kitchen but i doubt you would like Hell Fire.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Realm of Burning Nightmares[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• スキル使用と同時に火炎ダメージを適用する。"
		+ "\n• 火炎ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]12[/color]ポイント増加する。";

::Const.Strings.PerkDescription.NggHAlpShadowCopy <- "\'Two is better than one.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP7および疲労45を消費する。"
		+ "\n• 広範囲（[color=" + ::Const.UI.Color.PositiveValue + "]7[/color] tiles）を[color=" + ::Const.UI.Color.PositiveValue + "]3[/color] rounds持続する闇で覆うことができる。"
		+ "\n• すでに操作中のNightmare monsterがいない場合、闇マス内に1体出現させる。"
		+ "\n• Nightmare monsterが倒された後も、闇マスは自分のターン開始時にそのNightmare monsterを再出現させ続ける。";
// nacho
::Const.Strings.PerkDescription.NggHNacho <- "Master your ghoulish abilities.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Frenzy[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Ghoul Claws[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Skin Ghoul Claws[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Gruesome Feast[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Swallow Whole[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Throw Up[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。";

::Const.Strings.PerkDescription.NggHNachoEat <- "\'Eat and be strong! Ooga booga!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Gruesome Feast[/color]スキルを使用するたび、以下の効果を適用する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 1ターンごとの疲労回復量が[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]ポイント増加する。"
		+ "\n• 効果は[color=" + ::Const.UI.Color.PositiveValue + "]2[/color] turns持続する。";

::Const.Strings.PerkDescription.NggHNachoFrenzy <- "\'Thrist for blood.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP3および疲労25を消費する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]+50%[/color]増加する。"
		+ "\n• 近接防御が[color=" + ::Const.UI.Color.NegativeValue + "]-50%[/color]低下する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]Stun[/color]に免疫を得る。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]Knock Back[/color]または[color=" + ::Const.UI.Color.PositiveValue + "]Grab[/color]に免疫を得る。"
		+ "\n• すべてのアクティブスキルのAPコストが[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]減少する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.NegativeValue + "]Overwhelmed[/color]効果を付与する（[color=" + ::Const.UI.Color.NegativeValue + "]Overwhelm[/color]パークを習得していなくても有効）。"
		+ "\n• 効果は[color=" + ::Const.UI.Color.PositiveValue + "]2[/color] turns持続する。";

::Const.Strings.PerkDescription.NggHNachoVomit <- "\'Uwwwww owhwhwhwh!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP6および疲労15を消費する。"
		+ "\n• 'last meal'を胃の中から吐き出せるようにする。"
		+ "\n• このスキルを使用した後、次の自分のターンまで[color=" + ::Const.UI.Color.NegativeValue + "]Swallow Whole[/color]スキルを使用できない。";

::Const.Strings.PerkDescription.NggHNachoBigTummy <- "\'A bigger belly means a bigger defensive bonus.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Devour[/color]効果がある間、以下の効果を得る：\n"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]増加する。"
		+ "\n• 受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]減少する。精神攻撃や状態異常によるダメージには影響しない。";

::Const.Strings.PerkDescription.NggHNachoScavenger <- "\'A feast after work! Don\'t mind if i do.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 戦闘に参加した後、残された死体をむさぼり食い、そうした場合は[color=" + ::Const.UI.Color.NegativeValue + "]Well Fed[/color]効果を得る。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Well Fed効果：[/u][/color]"
		+ "\n• 以下の能力値のうち1つが[color=" + ::Const.UI.Color.NegativeValue + "]+25%[/color]増加する（AP、最大疲労、意思、イニシアチブ、近接攻撃スキル、近接防御、近接ダメージ、経験値獲得量）。"
		+ "\n• 1日の食料消費量[color=" + ::Const.UI.Color.PositiveValue + "]-25%[/color]"
		+ "\n• 1回の戦闘の間持続する";
// unhold
::Const.Strings.PerkDescription.NggH_Unhold_Grapple <- "\'Grab your opponent and manhandle them to the ground.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP5および疲労35を消費する。"
		+ "\n• 対象が[color=" + ::Const.UI.Color.NegativeValue + "]Immunity to Grab and Knockback[/color]を持つ場合、疲労ダメージを与えつつ2 turnsの間拘束し、確率で武装解除させる"
		+ "\n• 対象が[color=" + ::Const.UI.Color.NegativeValue + "]Immunity to Grab and Knockback[/color]を持たない場合、その対象を3回振り回し、防具値に基づくダメージを与える"
		+ "\n• 木を引き抜いたり岩を持ち上げたりするのにも使える。";

::Const.Strings.PerkDescription.NggH_Unhold_UnarmedAttack <- "\'Learn the basic of Hand-to-Hand combat.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP5および疲労20を消費する。"
		+ "\n• 単純な単体攻撃スキル。"
		+ "\n• 命中時に[color=" + ::Const.UI.Color.NegativeValue + "]100%[/color]の確率でstaggerさせる。";

::Const.Strings.PerkDescription.NggH_Unhold_UnarmedTraining <- "\'Focusing on technique, form and stances has given you greater control over your unarmed strikes.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Sweeping Strike[/color]スキルのダメージが、現在のヒットポイントの[color=" + ::Const.UI.Color.PositiveValue + "]3%[/color]に等しい値だけ増加する[b](max: 75)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]スキルは命中時に[color=" + ::Const.UI.Color.NegativeValue + "]25%[/color]の確率でdistractを付与する。"

::Const.Strings.PerkDescription.NggH_Unhold_SpecFists <- "\'Master the martial arts of unarmed combat.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Sweeping Strike[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルの命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルの疲労ダメージが増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]スキルの命中率と武装解除確率が増加する。"

::Const.Strings.PerkDescription.NggH_Unhold_Fling <- "\'When the throw can go to the moon.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Fling Back[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• APコストは[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]のみ。"
		+ "\n• 命中時に[color=" + ::Const.UI.Color.NegativeValue + "]Dazed[/color]効果を付与する。";
// schrat
::Const.Strings.PerkDescription.NggHSchratShield <- "\'Experience and instinct have given you a better understanding on how to grow and use shield more efficient.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Grow Shield[/color] and [color=" + ::Const.UI.Color.NegativeValue + "]Grow Greenwood Shield[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 使用時に[color=" + ::Const.UI.Color.NegativeValue + "]Shieldwall[/color]効果を得る。";

::Const.Strings.PerkDescription.NggHSchratSapling <- "\'Life-filled broken body part can easily be reborned into an intelligent Sapling.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 被弾後にSaplingが出現する確率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• Saplingはプレイヤーが直接操作できる。";

::Const.Strings.PerkDescription.NggHSchratUproot <- "\'Stronger root to make more servere wound.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Uproot[/color] and [color=" + ::Const.UI.Color.NegativeValue + "]Shatter The Earth[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]15[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。";

::Const.Strings.PerkDescription.NggHSchratUprootAoE <- "\'A ground erupting attack, sending rock shrapnels everywhere.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP6および疲労25を消費する。"
		+ "\n• 最大6体の対象に命中する。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• 隣接するすべてのユニットの[color=" + ::Const.UI.Color.NegativeValue + "]Spearwall[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Shieldwall[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Riposte[/color]効果を解除する。";
// lindwurm
::Const.Strings.PerkDescription.NggHLindwurmAcid <- "\'Hmm yes! An acid spitting dragon.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP5、60 HP、および疲労30を消費する。"
		+ "\n• 射程は[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]マス。"
		+ "\n• 対象とその近くにいる者へ酸性の血液を浴びせ、深刻な火傷を与え、あらゆる防具を溶かす。"
		+ "\n• 頭部に命中した場合、[color=" + ::Const.UI.Color.NegativeValue + "]Blinded[/color]効果を付与することがある。";

::Const.Strings.PerkDescription.NggHLindwurmIntimidate <- "\'Scare them with your huge c... I meant snake.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP7および疲労36を消費する。"
		+ "\n• 使用時、半径3 tiles以内のすべての敵に士気判定を行わせる。"
		+ "\n• 半径3 tiles以内のすべての敵の近接攻撃スキル、遠隔攻撃スキル、近接防御、遠隔防御、意思を最大[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]減少させる。"
		+ "\n• この効果は[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] turnのみ持続する。";

::Const.Strings.PerkDescription.NggHLindwurmBody <- "\'Stronger is better.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Gorge[/color], [color=" + ::Const.UI.Color.NegativeValue + "]Tail Thresh[/color], [color=" + ::Const.UI.Color.NegativeValue + "]Tail Sweep[/color] and [color=" + ::Const.UI.Color.NegativeValue + "]Tail Split[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。";
// kraken
::Const.Strings.PerkDescription.NggHKrakenBite <- "\'Your bite becomes more dangerous with sharpen teeth that can easily cause grievous bleelding.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]8[/color]-[color=" + ::Const.UI.Color.PositiveValue + "]18[/color]ポイント増加する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]の出血ダメージを与える。";

::Const.Strings.PerkDescription.NggHKrakenDevour <- "\'Hungrier than ever.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Devour[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• クールダウンを完全に取り除く。"
		+ "\n• 使用時、すべてのtentacleのヒットポイントを[color=" + ::Const.UI.Color.PositiveValue + "]25[/color]-[color=" + ::Const.UI.Color.PositiveValue + "]40[/color]回復する。";

::Const.Strings.PerkDescription.NggHKrakenEnsnare <- "\'When you think about being dragged to a big flicking mouth is bad enough, now imagine being squeezed to pulp before getting eaten.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Squeeze Prey[/color]のダメージが[color=" + ::Const.UI.Color.PositiveValue + "]35%[/color]増加し、この補正はtentacleにensnareされている間の継続ダメージにも適用される。";

::Const.Strings.PerkDescription.NggHKrakenMove <- "With the help of natural slime, your tenticles can move better than ever. Definitely not inspired by anything weird.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• tentacleは移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]2[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Move Tentacle[/color]スキルの最大射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]マス増加する。";

::Const.Strings.PerkDescription.NggHKrakenSwing <- "\'What better use of your tentacles than swinging it around? ...! Stop! we do not talk about that.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP5および疲労36を消費する。"
		+ "\n• 同時に最大3体の対象に命中する。"
		+ "\n• あなたのtentacle専用。";

::Const.Strings.PerkDescription.NggHKrakenTentacle <- "\'Your skin is like rubber or perhaps latex too?! Capable of deflecting attacks and harder to be cut.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 受けるすべてのダメージを[color=" + ::Const.UI.Color.PositiveValue + "]15[/color]ポイント減少させる。"
		+ "\n• 出血に免疫を得る。";
// mounting
::Const.Strings.PerkDescription.NggHGoblinMountTraining <- "\'Learn how to ride a mount.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• Wardog、Warhound、Wolfに騎乗できるようになる。";

::Const.Strings.PerkDescription.NggHGoblinMountedArchery <- "\'Learn the proper ways to use ranged weapon while riding mount.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n騎乗中、以下の効果を得る：\n"
		+ "\n• 遠隔ダメージのペナルティを取り除く。"
		+ "\n• 遠隔攻撃スキルのペナルティを[color=" + ::Const.UI.Color.NegativeValue + "]-35%[/color]から[color=" + ::Const.UI.Color.PositiveValue + "]-15%[/color]まで軽減する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mounted Charge[/color]効果がある場合、投擲武器は追加ダメージを得る。";

::Const.Strings.PerkDescription.LegendHorseLiberty = "\'Through extensive roundpenning training, the mount gains trust in the movements of the rider.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n騎乗中、以下の効果を得る：\n"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する";

::Const.Strings.PerkDescription.NggHGoblinMountedCharge <- "\'Use the great weight and speed of the mount to charge forward.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 最大威力のmounted chargeを溜めるために必要な移動マス数を減少させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mounted Charge[/color]効果のボーナスを元の値の[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]分だけ増加させる。";
// ghost
::Const.Strings.PerkDescription.NggHGhostGhastlyTouch <- "\'My touch is both fast and deadly!!!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Affected Skills:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Ghastly Touch[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• APコストが[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]減少する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.DamageValue + "]0[/color] - [color=" + ::Const.UI.Color.DamageValue + "]5[/color]の攻撃ダメージを得る。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHGhostSpectralBody <- "\'Like a shapeless moving shadow, You can hardly hit it.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 受けるすべての近接攻撃の命中率を[color=" + ::Const.UI.Color.PositiveValue + "]-10%[/color]低下させる。"
		+ "\n• すべての遠隔攻撃に対する完全な免疫を得る。";

::Const.Strings.PerkDescription.NggHGhostVanish <- "\'I was there seconds ago, now i am here.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• ダメージを受けたとき、自動的に別の場所へテレポートし、多くの場合は敵から少なくとも2-3 tiles離れる。";

::Const.Strings.PerkDescription.NggHGhostPhase <- "\'What do you think when you meet a ghost then seeing it passes through your body?\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP6および疲労0を消費する。"
		+ "\n• その対象をすり抜けて移動しながら、最大2体を攻撃できる。"
		+ "\n• 防具を無視するダメージを与える。";

::Const.Strings.PerkDescription.NggHGhostSoulEater <- "\'A ghost feasts on the soul of living being? Now that sounds scary.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Ghastly Touch[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Phase Through[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Banshee Scream[/color]スキルは、敵を倒した後に[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]の確率で[color=" + ::Const.UI.Color.NegativeValue + "]Nine Lives[/color]パークの残機を1つ回復する。";
// misc
::Const.Strings.PerkDescription.NggHMiscLineBreaker <- "\'Meat wall can not stop you, just break through it with brute force.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]Active:[/u][/color]"
		+ "\n• AP4および疲労30を消費する。"
		+ "\n• 敵の防衛線を突破して後衛まで到達できるようになる。";

::Const.Strings.PerkDescription.NggHMiscChampion <- "\'The toughest of the strongest of their kind.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Champion[/color]種族スキルを得る。";

::Const.Strings.PerkDescription.NggHMiscDaytime <- "\'There is nothing to be scared of the light. Embrace it!\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Daytime[/color]効果によるペナルティを大きく軽減する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]増加する。";

::Const.Strings.PerkDescription.NggHMiscNighttime <- "Nighttime is your time.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Nocturnal[/color]効果を得て、以下の効果が発生する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。"
		+ "\n• 近接防御が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• 遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Nighttime[/color]効果の影響を受けない。";

::Const.Strings.PerkDescription.NggHMiscFairGame <- "\'A fair trade off.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+25[/color]増加する。"
		+ "\n• 遠隔攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+25[/color]増加する。"
		+ "\n• 攻撃は[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]多くのダメージを与えるか、[color=" + ::Const.UI.Color.NegativeValue + "]50%[/color]少ないダメージを与えるかのどちらかになる。";
// simp
::Const.Strings.PerkDescription.NggH_Simp_NoFoodOnlyLove <- "\'I can never have enough of it.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Simp (lv. 1)[/color]以上である間、以下の効果を適用する：\n"
		+ "\n• 戦闘で得られる経験値が[color=" + ::Const.UI.Color.NegativeValue + "]50%[/color]減少する。"
		+ "\n• 食料消費量を[color=" + ::Const.UI.Color.PositiveValue + "]0[/color]にする。"
		+ "\n• このキャラクターが[color=" + ::Const.UI.Color.NegativeValue + "]Simp (lv. 10)[/color]に達したとき、消費したパークポイントが返還される。";

::Const.Strings.PerkDescription.NggH_Simp_Bodyguard <- "\'Proud to be the shield of my one true love.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Elder Hexe[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Hexe[/color]背景のいずれかから3 tiles以内にいる間、以下の効果を適用する：\n"
		+ "\n• 近接攻撃スキル、遠隔攻撃スキル、近接防御、遠隔防御、意思に[color=" + ::Const.UI.Color.PositiveValue + "]x%[/color]のボーナスを得る。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]x[/color]は[color=" + ::Const.UI.Color.NegativeValue + "](3 + Simp Level)[/color]に等しい"

::Const.Strings.PerkDescription.NggH_Simp_UndyingLove <- "\'Love is blind, and it is not a good thing in this case.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• このパークを習得すると、直ちにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。"
		+ "\n• Simp levelは[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]未満には低下しない。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Elder Hexe[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Hexe[/color]背景の近くに配置された場合、戦闘開始時の士気は常に[color=" + ::Const.UI.Color.PositiveValue + "]Confident[/color]になる。";

::Const.Strings.PerkDescription.NggH_Simp_LevelUp <- "\'The vicious cycle of a simp continues. Only the most foolish... i meant the strongest simp can stay.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• このパークを習得すると、直ちにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。"
		+ "\n• このパーク習得後、今後レベルを[color=" + ::Const.UI.Color.NegativeValue + "]2[/color]上げるごとにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。";

// basilisk
::Const.Strings.PerkDescription.NggH_Basilisk_AimTheHead <- "\'Go for the head, go for the kill.\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
		+ "\n• 頭部への命中に成功するたび、\"Aim For The Head\"を1スタック得る。"
		+ "\n• \"Aim For The Head\"1スタックごとに、頭部命中時のダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+12.5%[/color]増加する。[color=" + ::Const.UI.Color.NegativeValue + "]Head Hunter[/color]パークもある場合、このボーナスは2倍になる。"
		+ "\n• 6スタック以上に達すると、スタック数は[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]にリセットされる。[color=" + ::Const.UI.Color.NegativeValue + "]胴体に命中[/color]するとスタック数は[color=" + ::Const.UI.Color.NegativeValue + "]0[/color]にリセットされる";

// add more
::Const.Strings.PerkDescription.LegendLithe = "Medium armor provides a sweet spot between movement and protection."
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]Passive:[/u][/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "][u]人間および人型：[/u][/color]"
		+ "\n• このキャラクターの頭部防具と胴体防具の合計重量が[color=" + ::Const.UI.Color.NegativeValue + "]25[/color]から[color=" + ::Const.UI.Color.NegativeValue + "]35[/color]の間である必要がある"
		+ "\n• 防具とヒットポイントへのすべての被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]30%[/color]減少する。"
		+ "\n• 上記の重量範囲を外れると、ボーナスは指数的に低下する。防具がダメージを受けるにつれて、ボーナスはゆっくりと最大値の半分まで低下する。"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "][u]その他のキャラクター：[/u][/color]"
		+ "\n• ほとんどのダメージ源から受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。";
