//-------------
// description
// hexe charm specialized
::Const.Strings.PerkDescription.NggHCharmEnemySpider <- "\'森の奥に潜む気味の悪い虫たちも、あなたの下僕や兵士にするにはお似合いね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Webknechtを永続的に魅了できるようになる。"
		+ "\n• Redback Spiderを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• net、web、grasping vinesによる拘束に対する[color=" + ::Const.UI.Color.PositiveValue + "]免疫[/color]を得る。";

::Const.Strings.PerkDescription.NggHCharmEnemyDirewolf <- "\'5フィートもある大型犬をペットにしたくない人がいるかしら？あなたの敵を食い荒らす姿を見るより素敵なことはないわ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]\n• Direwolf、Hyena、Bearを永続的に魅了できるようになる。"
		+ "\n• White Direwolfを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]8%[/color]増加し、移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]2[/color]減少する。";

::Const.Strings.PerkDescription.NggHCharmEnemyAlp <- "\'夢喰いも悪夢を呼ぶ者も、あなたのような美女に仕えるべき存在よ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Alpを永続的に魅了できるようになる。"
		+ "\n• Demon Alpを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 恐怖、パニック、精神支配効果に対する士気判定で意思が[color=" + ::Const.UI.Color.PositiveValue + "]+15[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Sleep[/color]スキルの対象を眠らせる確率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemyGhoul <- "\'腹を空かせた猿や、飢えた巨大ゴリラも、なかなか珍しいペットになるはずよ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Nachzehrerを永続的に魅了できるようになる。"
		+ "\n• Skin Ghoulを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemyUnhold <- "\'最も背の高いオークすら見下ろすほどの巨人たち。そんな強大な存在をこそ、あなたの護衛にすべきね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Unhold、Frost Unhold、Swamp Unhold、Armored Unholdを永続的に魅了できるようになる。"
		+ "\n• Rock Unholdを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmEnemySchrat <- "\'森の守護者と見なされる、意識を持つ古代の樹木たち。彼らこそあなたの守護者に相応しいわ！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Schratを永続的に魅了できるようになる。"
		+ "\n• Heartwood Schratを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 近接防御と遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• 受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]減少する。精神攻撃や状態異常によるダメージには影響しない。";

::Const.Strings.PerkDescription.NggHCharmEnemyLindwurm <- "\'巨大な蛇と呼ぶ者もいれば、竜と呼ぶ者もいる。酸の血と聳え立つ体躯を持つ恐るべき獣たちを表す呼び名は様々。そんな一体を従えるところを想像してみて。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Lindwurmを永続的に魅了できるようになる。"
		+ "\n• Stollwurmを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• 近接戦闘中のあらゆる敵の意思を、自身の現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]に等しい値だけ減少させる。";

::Const.Strings.PerkDescription.NggHCharmEnemyOrk <- "\'人間には到底かなわない怪力を持つ戦士たち。その剛腕は、あなたの大義のために使われるべきよ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Orc Berserker、Orc Warrior、Orc Eliteを永続的に魅了できるようになる。"
		+ "\n• Orc WarlordとOrc Behemothを永続的に魅了するための2つの条件のうち1つを満たす。"
		+ "\n• イニシアチブは蓄積した疲労の全量ではなく、その[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]分だけ減少する。";

::Const.Strings.PerkDescription.NggHCharmEnemyGoblin <- "\'ゴブリンは小さく弱いけれど、袖の下にはたくさんの策を隠し持っている。そんな狡猾な生き物は、特定の仕事にうってつけね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Goblin OverseerとGoblin Shamanを永続的に魅了できるようになる。"
		+ "\n• overwhelmed状態に対する[color=" + ::Const.UI.Color.PositiveValue + "]免疫[/color]を得る。"
		+ "\n• 遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]ポイント増加する。";
// hexe charm base
::Const.Strings.PerkDescription.NggHCharmBasic <- "\'他人の心を盗む基本を学びなさい。まず最初のレッスン、熟れて瑞々しい果実をひと組見せれば、男はあなたの魅力に落ちるわ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]の取引能力を得て、売却価格が上がり、購入価格が下がり、配送契約の報酬が増加する。";

::Const.Strings.PerkDescription.NggHCharmWords <- "\'地の底で眠るどんな蛇も目覚めさせる、魅惑の言葉。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• より強力な人間、たとえばKnight、Sergent、Officer、Nomad Leader、Bandit Leader、Barbarian Chosenなどにも魅了を行えるようになる。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHCharmAppearance <- "\'どんな男も抗えない、豪奢な姿。これほどの美しさが存在していいのかしら？\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Swordmaster、Blade Dancer、Master Archer、Desert Stalker、Hedge Knight、Nomad Executioner、Barbarian King、Bandit Warlordを魅了できるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]魅了[/color]効果の持続時間が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] ターン増加する。この追加持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]強靭[/color]パークでは減少しない。";

::Const.Strings.PerkDescription.NggHCharmSpec <- "\'他人の心を掴む技を極めなさい。支配者気取りのお母さんが欲しくない？さあおいで！ママが慰めてあげる！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• 王者の敵を永続的に魅了できるようになる。\n• Orc Warlord、Orc Behemoth、伝説の獣を永続的に魅了するための最後の条件を満たす。";

::Const.Strings.PerkDescription.NggHCharmNudist <- "\'本物のふしだら者に、布切れなんて要らないわ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n防具と兜の両方を装備していない間、以下の効果を得る：\n"
		+ "\n• nimbleのスタックをさらに1つ得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";
// hexe hex
::Const.Strings.PerkDescription.NggHHexHexer <- "\'呪詛師が自らの呪いにどれほどの力を持つか、あなたは知らないでしょうね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果を受けている対象を攻撃する際、以下の効果を適用する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]増加する。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHHexMastery <- "\'呪詛の技を極めなさい。呪う力はこれ以上ないほど研ぎ澄まされる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]呪詛の守護[/color]効果がある場合、APコストを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]だけ減少させる。"
		+ "\n• 経験値獲得量が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHHexSharePain <- "\'苦しみを一人だけで背負う必要なんてないわ！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 視界内の別のランダムな敵1体にも追加で[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果を付与する。"
		+ "\n• 各ラウンドに1回、[color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]効果以外のあらゆるダメージ源によって自身のhex対象1体が受けたダメージは、他のhex対象にも与えられる。自身は対象外。";

::Const.Strings.PerkDescription.NggHHexSuffering <- "\'より大きな苦痛をもたらす呪い！あなたの重荷を彼らに背負わせなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]苦痛の呪詛[/color]に強化される。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]18%[/color]増加する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]苦痛の呪詛の効果：[/u][/color]"
		+ "\n• 特定の種類の負の状態異常（[color=" + ::Const.UI.Color.NegativeValue + "]出血[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]毒[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]朦朧[/color]など）をhex対象へ移し替える"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexWeakening <- "\'対象を弱く老いさせる呪い。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]弱体の呪詛[/color]に強化される。"
		+ "\n• 1ターンごとの疲労回復量が[color=" + ::Const.UI.Color.PositiveValue + "]14%[/color]増加する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]弱体の呪詛の効果：[/u][/color]"
		+ "\n• 攻撃ダメージ[color=" + ::Const.UI.Color.NegativeValue + "]-40%[/color]"
		+ "\n• 最大疲労[color=" + ::Const.UI.Color.NegativeValue + "]-33%[/color]"
		+ "\n• 1ターンごとの疲労回復量[color=" + ::Const.UI.Color.NegativeValue + "]-5[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexVulnerability <- "\'新たな傷をいつも以上に深く悪化させる呪い。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]脆弱の呪詛[/color]に強化される。"
		+ "\n• ヒットポイントへの被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント減少する。"
		+ "\n• 防具への被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15[/color]ポイント減少する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]脆弱の呪詛の効果：[/u][/color]"
		+ "\n• 受けるダメージ[color=" + ::Const.UI.Color.NegativeValue + "]+15%[/color]"
		+ "\n• イニシアチブ[color=" + ::Const.UI.Color.NegativeValue + "]-25%[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";

::Const.Strings.PerkDescription.NggHHexMisfortune <- "\'不運をもたらす呪い。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hex[/color]アクティブスキルが[color=" + ::Const.UI.Color.NegativeValue + "]不運の呪詛[/color]に強化される。"
		+ "\n• あらゆる攻撃者に対して命中させるために2回の攻撃判定成功を要求する確率を[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]得る。"
		+ "\n• あらゆる負の士気判定が自身に影響するために2回の判定成功を要求する確率を[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]得る。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]不運の呪詛の効果：[/u][/color]"
		+ "\n• 合計命中率[color=" + ::Const.UI.Color.NegativeValue + "]-12%[/color]"
		+ "\n• 合計回避率[color=" + ::Const.UI.Color.NegativeValue + "]-10%[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "]このパークグループでは1つのパークしか習得できず、それ以上は習得できない[/color]";
// hexe bdsm
::Const.Strings.PerkDescription.NggH_BDSM_WhipLash <- "\'あまりの速さに、遠くからでも弾ける音が聞こえるほど。これを避けられる者などいるかしら？\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n鞭を装備している間、以下の効果を得る：\n"
		+ "\n• 現在のイニシアチブの[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]に等しい近接攻撃スキルを得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]アクティブスキルは、自身と対象の間の1マスごとに攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]、防具貫通が[color=" + ::Const.UI.Color.PositiveValue + "]+6%[/color]増加する。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipMastery <- "\'鞭を極め、最も痛いところを的確に打ちなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• このパークは[color=" + ::Const.UI.Color.NegativeValue + "]Cleaver Mastery[/color]としても扱われる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、対象の[color=" + ::Const.UI.Color.NegativeValue + "]出血[/color]効果1スタックごとに攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。"
		+ "\n• 鞭武器スキルのAPコストが[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]減少する。";

::Const.Strings.PerkDescription.NggH_BDSM_MaskOn <- "\'ねえ、仮面をつけるのって背徳的かしら？\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n視界に少なくとも[color=" + ::Const.UI.Color.NegativeValue + "]-1[/color]の補正を与える頭装備を着けている間、以下の効果を得る：\n"
		+ "\n• 習得済みのこのパークグループのパーク1つごとに意思が[color=" + ::Const.UI.Color.PositiveValue + "]+3%[/color]増加する（このパークを含む）。"
		+ "\n• 鞭武器スキルの疲労コストを、習得済みのこのパークグループのパーク数だけ減少させる（このパークを含む）。";

::Const.Strings.PerkDescription.NggH_BDSM_Bondage <- "\'信じて、あなた。楽しい時間を過ごしましょうね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\nnet、vines、webに捕らわれている敵を有効なスキルで対象にしたとき、以下の効果を適用する：\n"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が[color=" + ::Const.UI.Color.PositiveValue + "]+7%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]、防具貫通が[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Disarm[/color]アクティブスキルの命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+12%[/color]増加する。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipPunish <- "\'ママの言う通りにしなさい、さもないと鞭を受けるわよ。\'"
	+"\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• 鞭を装備している間、[color=" + ::Const.UI.Color.NegativeValue + "]Crack the Whip[/color]アクティブスキルを得る。"
		+ "\n• AP4および疲労15を消費する。\n• 射程は[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]マス。"
		+ "\n• 対象に防具を無視する[color=" + ::Const.UI.Color.DamageValue + "]2[/color] - [color=" + ::Const.UI.Color.DamageValue + "]5[/color]ダメージを与える。"
		+ "\n• 対象のsimpに[color=" + ::Const.UI.Color.NegativeValue + "]Whipped[/color]状態を付与し、多くの能力値を2ラウンドの間上昇させる。"
		+ "\n• 対象のsimpの士気が\'Steady\'未満なら\'Steady\'に戻す。";

::Const.Strings.PerkDescription.NggH_BDSM_WhipLove <- "\'相手が喜んでいるなら、それは虐待とは呼ばないわ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color] "
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルが命中するたび、その対象に\"whipped\"カウンターを付与する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルは、その対象の\"whipped\"カウンター1つごとに魅了確率が[color=" + ::Const.UI.Color.PositiveValue + "]+4%[/color]増加する[b](max: 20%)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Whip[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]Flaggelate[/color]アクティブスキルは、現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]12%[/color]に等しい追加攻撃ダメージを得る[b](max: 30)[/b]。";

::Const.Strings.PerkDescription.NggH_BDSM_DommyMommy <- "\'やめろと言ったかしら？私がいいと言うまで続けなさい。さあ、口でちゃんと私の足を綺麗にして。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color] "
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Fearsome[/color]パークを無償で得る。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Crack the Whip[/color]スキルは自身の士気も上昇させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Crack A Whip[/color]スキルによる[color=" + ::Const.UI.Color.NegativeValue + "]Whipped[/color]効果のボーナスが[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]ポイント増加する。";
// luft
::Const.Strings.PerkDescription.NggHLuftPattingSpec <- "\'頭を撫でる技を極めなさい。撫でられずに済む頭など存在しない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]なでなで[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]なでなで[/color]スキルのダメージが[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]なでなで[/color]スキルは[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]の確率で対象を気逸れ状態にする。";

::Const.Strings.PerkDescription.NggHLuftUnholyFruits <- "\'ルフトは自分の背徳の果実を、とある目的のために使う術を身につけた。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Charm[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Captive Charm[/color]スキルの魅了確率が追加で[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]の取引能力を得て、売却価格が上がり、購入価格が下がり、配送契約の報酬が増加する。";

::Const.Strings.PerkDescription.NggHLuftInnocentLook <- "\'無垢で小柄なグールらしい見た目を利用し、油断した人間たちに『可愛い』と思わせ、警戒を解いたところで撫でてもらう。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n•より強力な人間、たとえばKnight、Sergent、Officer、Nomad Leader、Bandit Leader、Barbarian Chosenなどにも魅了を行えるようになる。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHLuftGhoulBeauty <- "\'どんな変態な人間もルフトに恋してしまう、魅惑的なグールの肉体。みんな私を好きになる！みんな私を愛してる！みんな私を撫でさせてくれる！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Swordmaster、Blade Dancer、Master Archer、Desert Stalker、Hedge Knight、Nomad Executioner、Barbarian King、Bandit Warlordを魅了できるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]魅了[/color]効果の持続時間が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] ターン増加する。この追加持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]強靭[/color]パークでは減少しない。";
// egg
::Const.Strings.PerkDescription.NggHEggBreedingMachine <- "\'得意なことを極めなさい。卵を産むこと、食べる方じゃないわよ！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hatch Egg[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Hatch All Eggs[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 各ターン開始時、[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]の確率で無料の卵を1つ得る。";

::Const.Strings.PerkDescription.NggHEggInherit <- "\'この親にしてこの子あり。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 孵化したspiderlingはあなたのパークの大半を引き継ぐ。";

::Const.Strings.PerkDescription.NggHEggNaturalSelection <- "\'あとは自然に任せなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 後から孵化したspiderlingほど基礎能力値が高くなる。";

::Const.Strings.PerkDescription.NggHEggAttachSpider <- "\'脚が無いというのは悲しいこと。脚を一対所望するなど贅沢すぎる願いというもの。まあ！！！少なくとも、蜘蛛の友達に乗せてもらうくらいはお願いできるわね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• SpiderやWardog、Warhound、Wolfなど特定の生物に騎乗できるようになる。";
// spider
::Const.Strings.PerkDescription.NggH_Spider_Bite <- "\'最も頑丈な鎧すら貫く、強力な蜘蛛の咬みつき。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]ウェブクネヒトの咬みつき[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]レッドバック・ウェブクネヒトの咬みつき[/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]1[/color]-[color=" + ::Const.UI.Color.DamageValue + "]5[/color]増加する。"
		+ "\n• 防具を無視するダメージ割合が追加で[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]の確率で完全に防具を無視する刺突攻撃になる。";

::Const.Strings.PerkDescription.NggH_Spider_Venom <- "\'さらに凶悪な毒。哀れな犠牲者はより早く命を落とすでしょう。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 咬みつきで付与する[color=" + ::Const.UI.Color.NegativeValue + "]毒[/color]効果の持続時間が1 ターン延長される。"
		+ "\n• 咬みつきで付与する[color=" + ::Const.UI.Color.NegativeValue + "]Redback 毒[/color]効果の1ターンごとの継続ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]増加する[b](min: 1)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]毒[/color]および[color=" + ::Const.UI.Color.NegativeValue + "]Redback 毒[/color]効果は、1スタックごとに対象の疲労消費を[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]ウェブクネヒトの咬みつき[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]レッドバック・ウェブクネヒトの咬みつき[/color]スキルの攻撃ダメージは、対象にある[color=" + ::Const.UI.Color.NegativeValue + "]毒[/color]および[color=" + ::Const.UI.Color.NegativeValue + "]Redback 毒[/color]効果1スタックごとに[color=" + ::Const.UI.Color.PositiveValue + "]2%[/color]増加する。"
		+ "\n• アンデッドに対してはダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"; //, but if they are trapped in net, vines or web then the bonus is increased to [color=" + ::Const.UI.Color.PositiveValue + "]25%[/color] instead.";

::Const.Strings.PerkDescription.NggH_Spider_Web <- "\'巣網を紡ぎ生み出す技を極め、少ない労力で最強の巣を張れるようになる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Weave Web[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 蓄積疲労が少ないほど、敵はあなたのwebから抜け出しにくくなる。"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• クールダウンを[color=" + ::Const.UI.Color.NegativeValue + "]1[/color] turnに減少させる。";

::Const.Strings.PerkDescription.NggH_Spider_ToughCarapace <- "\'並のプレートアーマーより頑丈。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 防具が受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]減少する。"
		+ "\n• 防具を無視するダメージを[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]減少させる";
// serpent
::Const.Strings.PerkDescription.NggHSerpentBite <- "\'電光石火の一撃で、より強力な咬みつきを繰り出す。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• APコストは[color=" + ::Const.UI.Color.PositiveValue + "]4[/color]のみ。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]8[/color]-[color=" + ::Const.UI.Color.DamageValue + "]15[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]増加する。";

::Const.Strings.PerkDescription.NggHSerpentDrag <- "\'強靭な筋肉により、どんな獲物もこの解けぬ締め付けで容易く無力化できる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 最大射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]マス増加する。"
		+ "\n• さらに最大で[color=" + ::Const.UI.Color.DamageValue + "]15[/color]の防具貫通ダメージも与える。";

::Const.Strings.PerkDescription.NggHSerpentVenom <- "\'進化して毒腺を得て、獲物に毒を仕込む。強力だが長くは持続しない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 1ターンごとに追加で[color=" + ::Const.UI.Color.DamageValue + "]20[/color]の毒ダメージを与える。"
		+ "\n• このパークで付与される[color=" + ::Const.UI.Color.NegativeValue + "]毒[/color]効果は1 ターンのみ持続する。";

::Const.Strings.PerkDescription.NggHSerpentGiant <- "\'大蛇より恐ろしいものなど何？それは、巨大な大蛇！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]スキルは、現在の近接攻撃スキルに応じた確率で引き寄せた対象を[color=" + ::Const.UI.Color.PositiveValue + "]Disarm[/color]する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Drag[/color]スキルで、ノックバックおよびつかみに免疫を持つ味方も引き寄せられるようになる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Serpent Bite[/color]スキルの攻撃射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]増加する。";
// hyena
::Const.Strings.PerkDescription.NggHHyenaBite <- "\'剃刀のように鋭い牙で、凄惨な出血傷を作り出す。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Hyena Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]30[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• 咬みつきで与える出血ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。";
// wolf
::Const.Strings.PerkDescription.NggHWolfBite <- "\'強靭な顎の筋肉と頑丈な牙で、鎧を砕き肉を引き裂く。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Direwolf Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]10[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]35%[/color]増加する。";

::Const.Strings.PerkDescription.NggHWolfThickHide <- "\'分厚く頑丈な毛皮が、重傷につながる攻撃を防いでくれる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 防具が受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]減少する。"
		+ "\n• 頭部と胴体の防具値に自然防具[color=" + ::Const.UI.Color.PositiveValue + "]75[/color]を得る。";

::Const.Strings.PerkDescription.NggHWolfEnrage <- "\'凶暴で素早い連撃により、圧倒された獲物には逃げることも抗うこともできなくなる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n対象にある[color=" + ::Const.UI.Color.NegativeValue + "]圧倒[/color]効果1スタックごとに、以下の効果を得る：\n"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• 防具を無視するダメージ割合が追加で[color=" + ::Const.UI.Color.PositiveValue + "]+2%[/color]増加する。";

::Const.Strings.PerkDescription.NggHWolfRabies <- "\'あなたの愛犬は狂犬病にかかっている。それは良くないわよね？撫でないで！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• ヒットポイントが[color=" + ::Const.UI.Color.PositiveValue + "]20[/color]ポイント増加する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]20[/color]ポイント増加する。";
// alp
::Const.Strings.PerkDescription.NggHAlpNightmareSpec <- "\'犠牲者の悪夢と恐怖を糧に、自らの活力を取り戻す。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]に等しい追加ダメージを得る。"
		+ "\n• 与えたダメージの最大[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]分のヒットポイントを回復する。";

::Const.Strings.PerkDescription.NggHAlpSleepSpec <- "\'獲物をより容易く眠らせる技を極める。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Sleep[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 対象を眠らせる確率が現在の意思の[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]だけ増加する。"
		+ "\n• APコストを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]だけ減少させる。";

::Const.Strings.PerkDescription.NggHAlpAfterWake <- "\'悪夢に起こされた獲物は、精神が脆くなっている。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 対象の意思を最大で[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]無視する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]の確率で対象を目覚めさせない。"
		+ "\n• あなたの攻撃で[color=" + ::Const.UI.Color.NegativeValue + "]Sleeping[/color]効果が解除されたとき、その睡眠中の対象に負の士気判定を行う。";

::Const.Strings.PerkDescription.NggHAlpAfterimage <- "\'これまで以上に鬱陶しい存在になる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n何らかの方法でテレポートした後、以下の効果を適用する：\n"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Afterimage[/color]効果を得て、近接防御と遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]+15[/color]増加し、次の自分のターン開始時まで持続する。"
		+ "\n• 追加の[color=" + ::Const.UI.Color.NegativeValue + "]Afterimage[/color]スタックは、それぞれ近接防御と遠隔防御を[color=" + ::Const.UI.Color.PositiveValue + "]+5[/color]だけ増加させる。";

::Const.Strings.PerkDescription.NggHAlpLivingNightmare <- "\'悪夢より恐ろしいものなど何？それは、夢の外に現れた悪夢。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 敵に止めを刺したとき、生けるNightmareを召喚する確率がある。"
		+ "\n• この確率は、その同じ対象に[color=" + ::Const.UI.Color.NegativeValue + "]Nightmare[/color]スキルを使った回数に応じて決まる。";

::Const.Strings.PerkDescription.NggHAlpMindBreak <- "\'断じて、どこかのいかがわしい創作物から出てきたようなものではない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP4および疲労8を消費する。"
		+ "\n• 防具を無視する[color=" + ::Const.UI.Color.DamageValue + "]5[/color] - [color=" + ::Const.UI.Color.DamageValue + "]10[/color]ダメージを与える。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]精神破壊[/color]効果を付与し、対象の意思を[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント低下させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]精神破壊[/color]効果は最大3 ターン持続し、重ね掛けもできる。";
// demon alp
::Const.Strings.PerkDescription.NggHAlpControlFlame <- "\'自分の炎をよく制御できるほど、あなたも安全になる。デーモン・アルプが2体を超える場合、炎同士が干渉し合うので注意すること。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]燃えさかる悪夢の領域[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 炎は術者を傷つけない。";

::Const.Strings.PerkDescription.NggHAlpFieceFlame <- "\'何もかも焼き尽くす荒れ狂う炎。地獄がここに現れる！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]燃えさかる悪夢の領域[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 火炎ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]20[/color]ポイント増加する。"
		+ "\n• 火炎ダメージは重度の火傷を引き起こすことがある。"
		+ "\n• 炎の持続時間は[color=" + ::Const.UI.Color.NegativeValue + "]半分[/color]になる。";

::Const.Strings.PerkDescription.NggHAlpHellishFlame <- "\'『ヘルズ・キッチン』は好きでも、こちらの業火はきっと気に入らないはずよ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]燃えさかる悪夢の領域[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• スキル使用と同時に火炎ダメージを適用する。"
		+ "\n• 火炎ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]12[/color]ポイント増加する。";

::Const.Strings.PerkDescription.NggHAlpShadowCopy <- "\'一つより二つの方がいい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP7および疲労45を消費する。"
		+ "\n• 広範囲（[color=" + ::Const.UI.Color.PositiveValue + "]7[/color] マス）を[color=" + ::Const.UI.Color.PositiveValue + "]3[/color] ラウンド持続する闇で覆うことができる。"
		+ "\n• すでに操作中の悪夢の怪物がいない場合、闇マス内に1体出現させる。"
		+ "\n• 悪夢の怪物が倒された後も、闇マスは自分のターン開始時にその悪夢の怪物を再出現させ続ける。";
// nacho
::Const.Strings.PerkDescription.NggHNacho <- "\'あなたのグールとしての能力を極めなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 最大疲労が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]狂乱[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]グールの鉤爪[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]スキングールの鉤爪[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]陰惨な饗宴[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]丸呑み[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]吐き出す[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。";

::Const.Strings.PerkDescription.NggHNachoEat <- "\'食べて、強くなれ！ウーガ・ブーガ！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]陰惨な饗宴[/color]スキルを使用するたび、以下の効果を適用する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 1ターンごとの疲労回復量が[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]ポイント増加する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]ポイント増加する。"
		+ "\n• 効果は[color=" + ::Const.UI.Color.PositiveValue + "]2[/color] ターン持続する。";

::Const.Strings.PerkDescription.NggHNacho狂乱 <- "\'血への渇望。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP3および疲労25を消費する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+15%[/color]増加する。"
		+ "\n• イニシアチブが[color=" + ::Const.UI.Color.PositiveValue + "]+50%[/color]増加する。"
		+ "\n• 近接防御が[color=" + ::Const.UI.Color.NegativeValue + "]-50%[/color]低下する。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]気絶[/color]に免疫を得る。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]ノックバック[/color]または[color=" + ::Const.UI.Color.PositiveValue + "]つかみ[/color]に免疫を得る。"
		+ "\n• すべてのアクティブスキルのAPコストが[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]減少する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.NegativeValue + "]圧倒[/color]効果を付与する（[color=" + ::Const.UI.Color.NegativeValue + "]圧倒[/color]パークを習得していなくても有効）。"
		+ "\n• 効果は[color=" + ::Const.UI.Color.PositiveValue + "]2[/color] ターン持続する。";

::Const.Strings.PerkDescription.NggHNachoVomit <- "\'うわぁぁぁ、おえぇぇぇ！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP6および疲労15を消費する。"
		+ "\n• 'last meal'を胃の中から吐き出せるようにする。"
		+ "\n• このスキルを使用した後、次の自分のターンまで[color=" + ::Const.UI.Color.NegativeValue + "]丸呑み[/color]スキルを使用できない。";

::Const.Strings.PerkDescription.NggHNachoBigTummy <- "\'大きなお腹は、大きな防御ボーナスの証。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Devour[/color]効果がある間、以下の効果を得る：\n"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]増加する。"
		+ "\n• 受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]15%[/color]減少する。精神攻撃や状態異常によるダメージには影響しない。";

::Const.Strings.PerkDescription.NggHNachoScavenger <- "\'仕事の後のご馳走！遠慮なくいただくとしよう。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 戦闘に参加した後、残された死体をむさぼり食い、そうした場合は[color=" + ::Const.UI.Color.NegativeValue + "]満腹[/color]効果を得る。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]満腹の効果：[/u][/color]"
		+ "\n• 以下の能力値のうち1つが[color=" + ::Const.UI.Color.NegativeValue + "]+25%[/color]増加する（AP、最大疲労、意思、イニシアチブ、近接攻撃スキル、近接防御、近接ダメージ、経験値獲得量）。"
		+ "\n• 1日の食料消費量[color=" + ::Const.UI.Color.PositiveValue + "]-25%[/color]"
		+ "\n• 1回の戦闘の間持続する";
// unhold
::Const.Strings.PerkDescription.NggH_Unhold_Grapple <- "\'相手を掴み、地面へと叩きつけろ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP5および疲労35を消費する。"
		+ "\n• 対象が[color=" + ::Const.UI.Color.NegativeValue + "]つかみ・ノックバック無効[/color]を持つ場合、疲労ダメージを与えつつ2 ターンの間拘束し、確率で武装解除させる"
		+ "\n• 対象が[color=" + ::Const.UI.Color.NegativeValue + "]つかみ・ノックバック無効[/color]を持たない場合、その対象を3回振り回し、防具値に基づくダメージを与える"
		+ "\n• 木を引き抜いたり岩を持ち上げたりするのにも使える。";

::Const.Strings.PerkDescription.NggH_Unhold_UnarmedAttack <- "\'徒手格闘の基本を学びなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP5および疲労20を消費する。"
		+ "\n• 単純な単体攻撃スキル。"
		+ "\n• 命中時に[color=" + ::Const.UI.Color.NegativeValue + "]100%[/color]の確率でよろめきさせる。";

::Const.Strings.PerkDescription.NggH_Unhold_UnarmedTraining <- "\'技術、フォーム、構えに集中することで、素手の一撃をより制御できるようになった。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルと[color=" + ::Const.UI.Color.NegativeValue + "]Sweeping Strike[/color]スキルのダメージが、現在のヒットポイントの[color=" + ::Const.UI.Color.PositiveValue + "]3%[/color]に等しい値だけ増加する[b](max: 75)[/b]。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]スキルは命中時に[color=" + ::Const.UI.Color.NegativeValue + "]25%[/color]の確率で気逸れを付与する。"

::Const.Strings.PerkDescription.NggH_Unhold_SpecFists <- "\'素手格闘の武術を極めなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Sweeping Strike[/color]スキルの疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルの命中率が[color=" + ::Const.UI.Color.PositiveValue + "]5%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Hand to Hand[/color]スキルの疲労ダメージが増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Grapple[/color]スキルの命中率と武装解除確率が増加する。"

::Const.Strings.PerkDescription.NggH_Unhold_Fling <- "\'投げ飛ばした相手が月まで届きそうなとき。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Fling Back[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• APコストは[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]のみ。"
		+ "\n• 命中時に[color=" + ::Const.UI.Color.NegativeValue + "]朦朧[/color]効果を付与する。";
// schrat
::Const.Strings.PerkDescription.NggHSchratShield <- "\'経験と本能により、盾の育て方と、より効率的な使い方への理解が深まった。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Grow Shield[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]生木の盾を育てる[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 使用時に[color=" + ::Const.UI.Color.NegativeValue + "]シールドウォール[/color]効果を得る。";

::Const.Strings.PerkDescription.NggHSchratSapling <- "\'命の残る千切れた体の一部は、知性を持つ苗木として容易く生まれ変わる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 被弾後にSaplingが出現する確率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• Saplingはプレイヤーが直接操作できる。";

::Const.Strings.PerkDescription.NggHSchratUproot <- "\'より強靭な根で、さらに深刻な傷を作り出す。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Uproot[/color]と[color=" + ::Const.UI.Color.NegativeValue + "]大地砕き[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.DamageValue + "]5[/color]-[color=" + ::Const.UI.Color.DamageValue + "]15[/color]ポイント増加する。"
		+ "\n• 防具への有効性が[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。";

::Const.Strings.PerkDescription.NggHSchratUprootAoE <- "\'地面が噴き上がる一撃で、岩の破片をあたり一面にまき散らす。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP6および疲労25を消費する。"
		+ "\n• 最大6体の対象に命中する。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• 隣接するすべてのユニットの[color=" + ::Const.UI.Color.NegativeValue + "]スピアウォール[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]シールドウォール[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]リポスト[/color]効果を解除する。";
// lindwurm
::Const.Strings.PerkDescription.NggHLindwurmAcid <- "\'うむ、いいぞ！酸を吐くドラゴンとはな。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP5、60 HP、および疲労30を消費する。"
		+ "\n• 射程は[color=" + ::Const.UI.Color.PositiveValue + "]3[/color]マス。"
		+ "\n• 対象とその近くにいる者へ酸性の血液を浴びせ、深刻な火傷を与え、あらゆる防具を溶かす。"
		+ "\n• 頭部に命中した場合、[color=" + ::Const.UI.Color.NegativeValue + "]盲目[/color]効果を付与することがある。";

::Const.Strings.PerkDescription.NggHLindwurmIntimidate <- "\'その大きな…いや、蛇で驚かせてやれ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP7および疲労36を消費する。"
		+ "\n• 使用時、半径3 マス以内のすべての敵に士気判定を行わせる。"
		+ "\n• 半径3 マス以内のすべての敵の近接攻撃スキル、遠隔攻撃スキル、近接防御、遠隔防御、意思を最大[color=" + ::Const.UI.Color.PositiveValue + "]20%[/color]減少させる。"
		+ "\n• この効果は[color=" + ::Const.UI.Color.PositiveValue + "]1[/color] turnのみ持続する。";

::Const.Strings.PerkDescription.NggHLindwurmBody <- "\'強い方がいいに決まっている。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Gorge[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Tail Thresh[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Tail Sweep[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Tail Split[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]10%[/color]増加する。";
// kraken
::Const.Strings.PerkDescription.NggHKrakenBite <- "\'鋭く研ぎ澄まされた牙により、咬みつきがさらに危険になり、凄惨な出血を容易く引き起こす。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Bite[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]8[/color]-[color=" + ::Const.UI.Color.PositiveValue + "]18[/color]ポイント増加する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.PositiveValue + "]5[/color]の出血ダメージを与える。";

::Const.Strings.PerkDescription.NggHKrakenDevour <- "\'これまで以上に飢えている。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Devour[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• クールダウンを完全に取り除く。"
		+ "\n• 使用時、すべてのtentacleのヒットポイントを[color=" + ::Const.UI.Color.PositiveValue + "]25[/color]-[color=" + ::Const.UI.Color.PositiveValue + "]40[/color]回復する。";

::Const.Strings.PerkDescription.NggHKrakenEnsnare <- "\'大きな口に引きずり込まれるだけでも十分恐ろしいのに、今度は食べられる前に押し潰されることまで想像してみて。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Squeeze Prey[/color]のダメージが[color=" + ::Const.UI.Color.PositiveValue + "]35%[/color]増加し、この補正はtentacleにensnareされている間の継続ダメージにも適用される。";

::Const.Strings.PerkDescription.NggHKrakenMove <- "\'天然の粘液のおかげで、あなたの触腕はかつてないほど滑らかに動く。断じて、変なものに触発されたわけではない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• tentacleは移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]2[/color]減少する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Move Tentacle[/color]スキルの最大射程が[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]マス増加する。";

::Const.Strings.PerkDescription.NggHKrakenSwing <- "\'触腕をただ振り回す以上の使い道とは何？…！やめて！その話はしないで。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP5および疲労36を消費する。"
		+ "\n• 同時に最大3体の対象に命中する。"
		+ "\n• あなたのtentacle専用。";

::Const.Strings.PerkDescription.NggHKrakenTentacle <- "\'あなたの皮膚はゴムか、それともラテックスかしら？！攻撃を弾き、切りにくくなる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 受けるすべてのダメージを[color=" + ::Const.UI.Color.PositiveValue + "]15[/color]ポイント減少させる。"
		+ "\n• 出血に免疫を得る。";
// mounting
::Const.Strings.PerkDescription.NggHGoblinMountTraining <- "\'騎乗の仕方を学びなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• Wardog、Warhound、Wolfに騎乗できるようになる。";

::Const.Strings.PerkDescription.NggHGoblinMountedArchery <- "\'騎乗しながら遠隔武器を扱う正しい方法を学びなさい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n騎乗中、以下の効果を得る：\n"
		+ "\n• 遠隔ダメージのペナルティを取り除く。"
		+ "\n• 遠隔攻撃スキルのペナルティを[color=" + ::Const.UI.Color.NegativeValue + "]-35%[/color]から[color=" + ::Const.UI.Color.PositiveValue + "]-15%[/color]まで軽減する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mounted Charge[/color]効果がある場合、投擲武器は追加ダメージを得る。";

::Const.Strings.PerkDescription.LegendHorseLiberty = "\'徹底した調馬索訓練により、乗騎は騎手の動きを信頼するようになる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n騎乗中、以下の効果を得る：\n"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]増加する。"
		+ "\n• 移動した1マスごとに疲労の蓄積が[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する";

::Const.Strings.PerkDescription.NggHGoblinMountedCharge <- "\'騎乗の重量と速度を活かし、前方へ突撃する。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 最大威力のmounted chargeを溜めるために必要な移動マス数を減少させる。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Mounted Charge[/color]効果のボーナスを元の値の[color=" + ::Const.UI.Color.PositiveValue + "]+25%[/color]分だけ増加させる。";
// ghost
::Const.Strings.PerkDescription.NggHGhostGhastlyTouch <- "\'私の接触は速く、そして致命的！！！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]対象スキル:[/u][/color] [color=" + ::Const.UI.Color.NegativeValue + "]Ghastly Touch[/color]"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• APコストが[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]減少する。"
		+ "\n• 追加で[color=" + ::Const.UI.Color.DamageValue + "]0[/color] - [color=" + ::Const.UI.Color.DamageValue + "]5[/color]の攻撃ダメージを得る。"
		+ "\n• 命中率が[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。";

::Const.Strings.PerkDescription.NggHGhostSpectralBody <- "\'形なき揺らめく影のように、あなたを捉えることはほとんどできない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 受けるすべての近接攻撃の命中率を[color=" + ::Const.UI.Color.PositiveValue + "]-10%[/color]低下させる。"
		+ "\n• すべての遠隔攻撃に対する完全な免疫を得る。";

::Const.Strings.PerkDescription.NggHGhostVanish <- "\'数秒前はそこにいたのに、今はここにいる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• ダメージを受けたとき、自動的に別の場所へテレポートし、多くの場合は敵から少なくとも2-3 マス離れる。";

::Const.Strings.PerkDescription.NggHGhostPhase <- "\'幽霊に出会い、それが自分の体をすり抜けていくのを見たら、何を思う？\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP6および疲労0を消費する。"
		+ "\n• その対象をすり抜けて移動しながら、最大2体を攻撃できる。"
		+ "\n• 防具を無視するダメージを与える。";

::Const.Strings.PerkDescription.NggHGhostSoulEater <- "\'幽霊が生者の魂を喰らう？それは実に恐ろしい話ね。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Ghastly Touch[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Phase Through[/color]、[color=" + ::Const.UI.Color.NegativeValue + "]Banshee Scream[/color]スキルは、敵を倒した後に[color=" + ::Const.UI.Color.PositiveValue + "]33%[/color]の確率で[color=" + ::Const.UI.Color.NegativeValue + "]Nine Lives[/color]パークの残機を1つ回復する。";
// misc
::Const.Strings.PerkDescription.NggHMiscLineBreaker <- "\'肉の壁もあなたを止められない、力ずくで突き破ってしまえ。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Active + "][u]アクティブ:[/u][/color]"
		+ "\n• AP4および疲労30を消費する。"
		+ "\n• 敵の防衛線を突破して後衛まで到達できるようになる。";

::Const.Strings.PerkDescription.NggHMiscChampion <- "\'その種族の中でも最強にして最強。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Champion[/color]種族スキルを得る。";

::Const.Strings.PerkDescription.NggHMisc昼行 <- "\'光を恐れることなど何もない。受け入れなさい！\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]昼行[/color]効果によるペナルティを大きく軽減する。"
		+ "\n• 意思が[color=" + ::Const.UI.Color.PositiveValue + "]10[/color]増加する。";

::Const.Strings.PerkDescription.NggHMisc夜間 <- "\'夜こそがあなたの時間。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]夜行性[/color]効果を得て、以下の効果が発生する：\n"
		+ "\n• 攻撃ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+5%[/color]増加する。"
		+ "\n• 近接防御が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• 遠隔防御が[color=" + ::Const.UI.Color.PositiveValue + "]+10%[/color]増加する。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]夜間[/color]効果の影響を受けない。";

::Const.Strings.PerkDescription.NggHMiscFairGame <- "\'公平な取引。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 近接攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+25[/color]増加する。"
		+ "\n• 遠隔攻撃スキルが[color=" + ::Const.UI.Color.PositiveValue + "]+25[/color]増加する。"
		+ "\n• 攻撃は[color=" + ::Const.UI.Color.PositiveValue + "]50%[/color]多くのダメージを与えるか、[color=" + ::Const.UI.Color.NegativeValue + "]50%[/color]少ないダメージを与えるかのどちらかになる。";
// simp
::Const.Strings.PerkDescription.NggH_Simp_NoFoodOnlyLove <- "\'これはいくらあっても足りないくらい。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Simp (lv. 1)[/color]以上である間、以下の効果を適用する：\n"
		+ "\n• 戦闘で得られる経験値が[color=" + ::Const.UI.Color.NegativeValue + "]50%[/color]減少する。"
		+ "\n• 食料消費量を[color=" + ::Const.UI.Color.PositiveValue + "]0[/color]にする。"
		+ "\n• このキャラクターが[color=" + ::Const.UI.Color.NegativeValue + "]Simp (lv. 10)[/color]に達したとき、消費したパークポイントが返還される。";

::Const.Strings.PerkDescription.NggH_Simp_Bodyguard <- "\'唯一無二の愛する者の盾となれることを誇りに思う。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n[color=" + ::Const.UI.Color.NegativeValue + "]Elder Hexe[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Hexe[/color]背景のいずれかから3 マス以内にいる間、以下の効果を適用する：\n"
		+ "\n• 近接攻撃スキル、遠隔攻撃スキル、近接防御、遠隔防御、意思に[color=" + ::Const.UI.Color.PositiveValue + "]x%[/color]のボーナスを得る。"
		+ "\n• [color=" + ::Const.UI.Color.PositiveValue + "]x[/color]は[color=" + ::Const.UI.Color.NegativeValue + "](3 + Simp Level)[/color]に等しい"

::Const.Strings.PerkDescription.NggH_Simp_UndyingLove <- "\'恋は盲目、そしてこの場合それは決して良いことではない。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• このパークを習得すると、直ちにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。"
		+ "\n• Simp levelは[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]未満には低下しない。"
		+ "\n• [color=" + ::Const.UI.Color.NegativeValue + "]Elder Hexe[/color]または[color=" + ::Const.UI.Color.NegativeValue + "]Hexe[/color]背景の近くに配置された場合、戦闘開始時の士気は常に[color=" + ::Const.UI.Color.PositiveValue + "]Confident[/color]になる。";

::Const.Strings.PerkDescription.NggH_Simp_LevelUp <- "\'貢がされる者の悪循環は続く。最も愚か…いや、最も強い貢がされ手だけが生き残れる。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• このパークを習得すると、直ちにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。"
		+ "\n• このパーク習得後、今後レベルを[color=" + ::Const.UI.Color.NegativeValue + "]2[/color]上げるごとにSimp Levelを[color=" + ::Const.UI.Color.PositiveValue + "]1[/color]得る。";

// basilisk
::Const.Strings.PerkDescription.NggH_Basilisk_AimTheHead <- "\'頭を狙え、仕留めるために。\'"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
		+ "\n• 頭部への命中に成功するたび、\"頭部狙い\"を1スタック得る。"
		+ "\n• \"頭部狙い\"1スタックごとに、頭部命中時のダメージが[color=" + ::Const.UI.Color.PositiveValue + "]+12.5%[/color]増加する。[color=" + ::Const.UI.Color.NegativeValue + "]首狩り[/color]パークもある場合、このボーナスは2倍になる。"
		+ "\n• 6スタック以上に達すると、スタック数は[color=" + ::Const.UI.Color.NegativeValue + "]1[/color]にリセットされる。[color=" + ::Const.UI.Color.NegativeValue + "]胴体に命中[/color]するとスタック数は[color=" + ::Const.UI.Color.NegativeValue + "]0[/color]にリセットされる";

// add more
::Const.Strings.PerkDescription.LegendLithe = "中装鎧は機動力と防御力の絶妙な均衡点を提供する。"
	+ "\n\n[color=" + ::Const.UI.Color.Passive + "][u]パッシブ:[/u][/color]"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "][u]人間および人型：[/u][/color]"
		+ "\n• このキャラクターの頭部防具と胴体防具の合計重量が[color=" + ::Const.UI.Color.NegativeValue + "]25[/color]から[color=" + ::Const.UI.Color.NegativeValue + "]35[/color]の間である必要がある"
		+ "\n• 防具とヒットポイントへのすべての被ダメージが[color=" + ::Const.UI.Color.PositiveValue + "]30%[/color]減少する。"
		+ "\n• 上記の重量範囲を外れると、ボーナスは指数的に低下する。防具がダメージを受けるにつれて、ボーナスはゆっくりと最大値の半分まで低下する。"
	+ "\n\n[color=" + ::Const.UI.Color.NegativeValue + "][u]その他のキャラクター：[/u][/color]"
		+ "\n• ほとんどのダメージ源から受けるダメージが[color=" + ::Const.UI.Color.PositiveValue + "]25%[/color]減少する。";
