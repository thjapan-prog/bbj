 local tr = function(s) {
   if (s == null) return s;
   if (typeof s != "string") return s;
   if (s in nameByText) return nameByText[s];
   return s;
 }
 local patchStringTable = function(tab) {
   if (tab == null || typeof tab != "table") return;
   foreach (k, v in tab) {
     if (typeof v == "string") tab[k] = tr(v);
   }
 }
 local patchPerkDef = function(p) {
   if (p == null || typeof p != "table") return;
   if (("ID" in p) && (p.ID in nameByID)) p.Name = nameByID[p.ID];
   else if (("Name" in p)) p.Name = tr(p.Name);
   if (("Tooltip" in p)) p.Tooltip = tr(p.Tooltip);
   if (("Description" in p)) p.Description = tr(p.Description);
 }
 if (("Const" in gt)) {
   if (("Strings" in gt.Const)) {
     if (("PerkName" in gt.Const.Strings)) {
       foreach (k, v in perkNameByKey) { gt.Const.Strings.PerkName[k] <- v; }
       patchStringTable(gt.Const.Strings.PerkName);
     }
     if (("PerkDescription" in gt.Const.Strings)) patchStringTable(gt.Const.Strings.PerkDescription);
     if (("SkillName" in gt.Const.Strings)) patchStringTable(gt.Const.Strings.SkillName);
   }
   if (("Perks" in gt.Const)) {
     if (("PerkDefObjects" in gt.Const.Perks)) { foreach (p in gt.Const.Perks.PerkDefObjects) patchPerkDef(p); }
     if (("PerkDefs" in gt.Const.Perks)) { foreach (k, p in gt.Const.Perks.PerkDefs) patchPerkDef(p); }
     foreach (k, p in gt.Const.Perks) { if (typeof p == "table") patchPerkDef(p); }
   }
 }
 if (("Legends" in gt)) {
   if (("Perks" in gt.Legends) && typeof gt.Legends.Perks == "table") {
     if (("PerkDefObjects" in gt.Legends.Perks)) { foreach (p in gt.Legends.Perks.PerkDefObjects) patchPerkDef(p); }
     if (("PerkDefs" in gt.Legends.Perks)) { foreach (k, p in gt.Legends.Perks.PerkDefs) patchPerkDef(p); }
   }
 }
});
