::mods_registerMod("mod_99_legends_complete_ja_v16_extra", 1.6, "Legends Complete Japanese Patch v16 Extra Repair");
local gt = this.getroottable();
local replaceText = function(text, substr, replace) { if (substr == "") return text; local right = text; local ret = ""; local i = right.find(substr); while (i != null) { local left = right.slice(0, i); right = right.slice(i + substr.len()); ret = ret + left + replace; i = right.find(substr); } return ret + right; }
