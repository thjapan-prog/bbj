 local patchStringTable = function(tab) { if (tab == null || typeof tab != "table") return; foreach(k,v in tab) if (typeof v == "string" && (v in nameByText)) tab[k] = nameByText[v]; };
 local patchPerkDef = function(p) { if (p == null || typeof p != "table") return; if (("ID" in p) && (p.ID in nameByID)) p.Name = nameByID[p.ID]; else if (("Name" in p) && (p.Name in nameByText)) p.Name = nameByText[p.Name]; };
 if (("Const" in gt)) {
   if (("Strings" in gt.Const)) {
     if (("PerkName" in gt.Const.Strings)) { foreach(k,v in perkNameByKey) gt.Const.Strings.PerkName[k] <- v; patchStringTable(gt.Const.Strings.PerkName); }
     if (("SkillName" in gt.Const.Strings)) patchStringTable(gt.Const.Strings.SkillName);
     if (("TraitName" in gt.Const.Strings)) patchStringTable(gt.Const.Strings.TraitName);
     if (("FT" in gt.Const.Strings) && ("SkillList" in gt.Const.Strings.FT)) patchFantasyBroSkillListV16();
   }
   if (("Perks" in gt.Const)) {
      if (("PerkDefObjects" in gt.Const.Perks)) foreach(p in gt.Const.Perks.PerkDefObjects) patchPerkDef(p);
      if (("PerkDefs" in gt.Const.Perks)) foreach(k,p in gt.Const.Perks.PerkDefs) patchPerkDef(p);
   }
 }
